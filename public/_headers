# Security headers for all static responses (Cloudflare Pages _headers).
# The "! Access-Control-Allow-Origin" line removes the Pages platform-default
# CORS wildcard — same-origin fetches do not need it.
# Fonts are self-hosted (@fontsource-variable/*), so the CSP needs no
# external style/font sources.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self'; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com https://www.youtube-nocookie.com https://www.youtube.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
  ! Access-Control-Allow-Origin

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="no"
  title="Siden finnes ikke (404) | Bordhockeyforbundet"
  description="Siden du lette etter finnes ikke."
  canonicalPath="/404"
  noUrl={null}
  enUrl={null}
  noindex={true}
>
  <section class="mx-auto max-w-3xl px-4 py-16 text-center">
    <p class="text-6xl font-extrabold text-navy">404</p>
    <h1 class="mt-4 text-3xl font-extrabold text-navy">Siden finnes ikke</h1>
    <p class="mt-3 text-slate-600">
      Beklager — siden du lette etter er flyttet eller finnes ikke. Prøv en av disse i stedet:
    </p>
    <nav class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-outline">Hjem</a>
      <a href="/turneringer/" class="btn-outline">Turneringer</a>
      <a href="/blog/" class="btn-outline">Nyheter</a>
    </nav>
  </section>
</BaseLayout>

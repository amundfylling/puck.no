---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="no"
  title="404 – Kioskenstrøm | Bordhockeyforbundet"
  description="Siden du lette etter finnes ikke."
  canonicalPath="/404"
  noUrl={null}
  enUrl={null}
  noindex={true}
>
  <section class="mx-auto max-w-2xl px-4 py-16 text-center sm:py-24">
    <p aria-hidden="true" class="text-8xl font-extralight leading-none tracking-tight text-navy/25 sm:text-9xl">
      404
    </p>
    <h1 class="mt-4 text-4xl font-extrabold text-navy sm:text-5xl">Kioskenstrøm</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-slate-600">
      Ikke ta det personlig. Ingen har scoret en Kioskenstrøm i offisiell kamp, og ingen har
      funnet denne siden. Du er i hvert fall i godt selskap.
    </p>

    <div class="mt-8">
      <a href="/lær-bordhockey-kombinasjoner/" class="btn-primary">Lær deg en Kioskenstrøm i stedet</a>
      <p class="mt-3 text-sm text-slate-500">Den er umulig den også, men over 200 andre triks finnes faktisk.</p>
    </div>
    <nav aria-label="Videre" class="mt-12 text-sm text-slate-500">
      <a href="/" class="font-semibold text-navy no-underline hover:text-brand hover:underline">Forsiden</a>
      <span aria-hidden="true" class="mx-2">·</span>
      <a href="/turneringer/" class="font-semibold text-navy no-underline hover:text-brand hover:underline"
        >Turneringer</a
      >
      <span aria-hidden="true" class="mx-2">·</span>
      <a href="/blog/" class="font-semibold text-navy no-underline hover:text-brand hover:underline">Nyheter</a>
    </nav>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';
import { getEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import heroImg from '../assets/images/hero.png';
import { getPosts, getTournamentsSorted } from '../lib/content';
import { seoForPath } from '../lib/seo';

const entry = await getEntry('pages', 'index');
if (!entry) throw new Error('pages/index not found');
const seo = seoForPath('/');
const posts = (await getPosts('no')).slice(0, 3);
const upcoming = (await getTournamentsSorted()).filter((v) => v.status === 'upcoming');
const next = upcoming[0] ?? null;
const rest = upcoming.slice(1);

// Dedicated 1200x630 og:image (cropped from the hero) for the front page.
const og = await getImage({ src: heroImg, width: 1200, height: 630, fit: 'cover', format: 'jpg' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'Norges Bordhockeyforbund',
  alternateName: 'NBHF',
  url: 'https://www.puck.no/',
  logo: 'https://www.puck.no/favicon.png',
  sport: 'Table hockey',
  email: 'amund.fylling@puck.no',
  address: { '@type': 'PostalAddress', addressCountry: 'NO' },
};
---

<BaseLayout
  lang="no"
  title={seo?.title ?? entry.data.seoTitle ?? entry.data.title}
  description={seo?.description || entry.data.description}
  canonicalPath="/"
  noUrl="/"
  enUrl="/en"
  ogImage={og.src}
  jsonLd={jsonLd}
>
  <HomePage lang="no" entry={entry} posts={posts} next={next} rest={rest} />
</BaseLayout>

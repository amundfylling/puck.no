---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTournamentsSorted } from '../../lib/content';

const views = await getTournamentsSorted();
---

<BaseLayout
  lang="no"
  title="Påmeldinger (admin) | Bordhockeyforbundet"
  description={null}
  canonicalPath="/admin/pameldinger"
  noUrl="/admin/pameldinger"
  enUrl={null}
  noindex={true}
>
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-extrabold text-navy">Påmeldinger (admin)</h1>
    <p class="mt-3 rounded-lg border border-slate-300 bg-ice px-4 py-3 text-sm text-slate-700">
      Denne siden krever styretilgang via Cloudflare Access. CSV-filene inneholder e-post og
      telefonnummer — håndter dem i henhold til personvernerklæringen (se «Data &amp; privacy» i
      README).
    </p>
    <ul class="mt-6 space-y-3">
      {
        views.map(({ entry, status }) => (
          <li class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <div>
              <p class="font-semibold text-navy">{entry.data.name}</p>
              <p class="text-sm text-slate-500">
                {entry.data.date} · {status === 'upcoming' ? 'Kommende' : 'Tidligere'}
              </p>
            </div>
            <a
              href={`/api/admin/registrations.csv?slug=${entry.data.slug}`}
              target="_blank"
              rel="noopener"
              class="btn-outline !px-3 !py-1.5 text-sm"
            >
              Last ned CSV
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

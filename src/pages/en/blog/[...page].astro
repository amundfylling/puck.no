---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogIndex from '../../../components/BlogIndex.astro';
import { BLOG_PAGE_SIZE, getPosts, postCategories } from '../../../lib/content';
import { seoForPath } from '../../../lib/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getPosts('en');
  const pageCount = Math.max(1, Math.ceil(posts.length / BLOG_PAGE_SIZE));
  return Array.from({ length: pageCount }, (_, i) => i + 1).map((page) => ({
    params: { page: page === 1 ? undefined : String(page) },
    props: {
      page,
      pageCount,
      posts: posts.slice((page - 1) * BLOG_PAGE_SIZE, page * BLOG_PAGE_SIZE),
      categories: postCategories(posts),
    },
  }));
}) satisfies GetStaticPaths;

const { page, pageCount, posts, categories } = Astro.props;
const entry = await getEntry('pages', 'en/blog');
if (!entry) throw new Error('pages/en/blog not found');
const path = page === 1 ? '/en/blog' : `/en/blog/${page}`;
const seo = seoForPath('/en/blog');
const baseTitle = seo?.title ?? entry.data.seoTitle ?? entry.data.title;
const title = page === 1 ? baseTitle : `${baseTitle} – Page ${page}`;
---

<BaseLayout
  lang="en"
  title={title}
  description={seo?.description || entry.data.description}
  canonicalPath={path}
  noUrl={path.replace(/^\/en/, '')}
  enUrl={path}
>
  <BlogIndex lang="en" entry={entry} posts={posts} page={page} pageCount={pageCount} categories={categories} />
</BaseLayout>

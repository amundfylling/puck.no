---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RegistrationForm from '../../../components/RegistrationForm.astro';
import ParticipantList from '../../../components/ParticipantList.astro';
import { tournamentImage, tournamentStatus } from '../../../lib/content';
import { formatNoDate, parseNoDate } from '../../../lib/dates';
import { seoForPath } from '../../../lib/seo';
import { t } from '../../../lib/i18n';
import registrations from '../../../data/registrations-snapshot.json';
import type { GetStaticPaths } from 'astro';

interface Player {
  name: string;
  country: string;
  world_ranking?: string;
}

export const getStaticPaths = (async () => {
  const tournaments = await getCollection('tournaments', (t) => t.data.lang === 'en');
  return tournaments.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const status = tournamentStatus(entry);
const hero = tournamentImage(entry);
const date = parseNoDate(entry.data.date);
const path = `/en/turneringer/${entry.data.slug}`;
const seo = seoForPath(path);
const players =
  (registrations.tournaments as Record<string, Player[]>)[entry.data.slug]?.filter(
    (p) => p.name && p.name.toLowerCase() !== 'name',
  ) ?? [];
const priceList = entry.data.prices?.split(';').map((s) => s.trim()).filter(Boolean) ?? [];
const systemList =
  entry.data.playingSystem?.split(';').map((s) => s.trim()).filter(Boolean) ?? [];
const facts: { label: string; lines: string[] }[] = [
  { label: t('en', 'date'), lines: [formatNoDate(entry.data.date, 'en')] },
  ...(entry.data.location ? [{ label: t('en', 'location'), lines: [entry.data.location] }] : []),
  ...(priceList.length ? [{ label: t('en', 'prices'), lines: priceList }] : []),
  ...(systemList.length ? [{ label: t('en', 'playingSystem'), lines: systemList }] : []),
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: entry.data.name,
  url: `https://www.puck.no${path}`,
  ...(date && { startDate: date.toISOString().slice(0, 10) }),
  eventStatus:
    status === 'past' ? 'https://schema.org/EventCompleted' : 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: entry.data.location ?? 'Norway',
    address: { '@type': 'PostalAddress', addressCountry: 'NO' },
  },
  organizer: {
    '@type': 'SportsOrganization',
    name: 'Norwegian Table Hockey Association',
    url: 'https://www.puck.no/en',
  },
};
---

<BaseLayout
  lang="en"
  title={seo?.title ?? `${entry.data.name} | Bordhockeyforbundet`}
  description={seo?.description || null}
  canonicalPath={path}
  noUrl={path.replace(/^\/en/, '')}
  enUrl={path}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <p class="text-sm">
      <a href="/en/turneringer" class="font-semibold text-brand no-underline hover:underline"
        >&larr; {t('en', 'tournaments')}</a
      >
    </p>

    <header class="relative mt-4 overflow-hidden rounded-2xl bg-navy">
      {
        hero && (
          <img
            src={hero}
            alt={entry.data.name}
            class="absolute inset-0 h-full w-full object-cover"
          />
        )
      }
      {hero && <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/55 to-navy/10" />}
      <div class="relative flex min-h-56 flex-col justify-end p-6 sm:min-h-72 sm:p-8">
        <div>
          <span
            class:list={[
              'rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide',
              status === 'upcoming' ? 'bg-brand text-white' : 'bg-white/85 text-slate-600',
            ]}>{t('en', status)}</span
          >
        </div>
        <h1 class="mt-3 text-3xl font-extrabold text-white sm:text-4xl">{entry.data.name}</h1>
        <p class="mt-1 text-sm font-semibold text-white/85 sm:text-base">
          {formatNoDate(entry.data.date, 'en')}{entry.data.location && ` · ${entry.data.location}`}
        </p>
      </div>
      {
        status === 'upcoming' && (
          <a
            href="#registration"
            class="absolute bottom-6 right-6 hidden rounded-full bg-white px-5 py-2.5 text-sm font-bold text-brand no-underline shadow-lg hover:bg-ice sm:inline-block"
          >
            {t('en', 'registerPlayer')}
          </a>
        )
      }
    </header>

    <div class="relative z-10 mx-2 -mt-8 grid gap-3 sm:mx-4 sm:grid-cols-2">
      {
        facts.map((fact) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-md">
            <p class="text-xs font-bold uppercase tracking-wide text-slate-500">{fact.label}</p>
            {fact.lines.length === 1 ? (
              <p class="mt-1 font-semibold text-navy">{fact.lines[0]}</p>
            ) : (
              <ul class="mt-1 space-y-0.5 text-sm font-semibold text-navy">
                {fact.lines.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <nav aria-label={entry.data.name} class="mt-4 flex flex-wrap gap-2 text-sm font-semibold">
      <a
        href="#schedule"
        class="rounded-full bg-ice px-3 py-1.5 text-navy no-underline hover:bg-navy hover:text-white"
        >{t('en', 'schedule')}</a
      >
      {
        status === 'upcoming' && (
          <a
            href="#registration"
            class="rounded-full bg-ice px-3 py-1.5 text-navy no-underline hover:bg-navy hover:text-white"
          >
            {t('en', 'registerPlayer')}
          </a>
        )
      }
      <a
        href="#participants"
        class="rounded-full bg-ice px-3 py-1.5 text-navy no-underline hover:bg-navy hover:text-white"
        >{t('en', 'registeredPlayers')}</a
      >
    </nav>

    <div class:list={['rich-text tournament-body mt-6', hero && 'hide-first-image']}>
      <Content />
    </div>

    {
      status === 'upcoming' && (
        <div id="registration" class="scroll-mt-6">
          <RegistrationForm lang="en" slug={entry.data.slug} teamMin={entry.data.teamMin} teamMax={entry.data.teamMax} />
        </div>
      )
    }

    <div id="participants" class="scroll-mt-6">
      <ParticipantList slug={entry.data.slug} players={players} lang="en" />
    </div>
  </article>
</BaseLayout>

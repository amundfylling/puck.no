---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RegistrationForm from '../../../components/RegistrationForm.astro';
import ParticipantList from '../../../components/ParticipantList.astro';
import { tournamentImage, tournamentStatus } from '../../../lib/content';
import { formatNoDate, parseNoDate } from '../../../lib/dates';
import { seoForPath } from '../../../lib/seo';
import { t } from '../../../lib/i18n';
import registrations from '../../../data/registrations-snapshot.json';
import type { GetStaticPaths } from 'astro';

interface Player {
  name: string;
  country: string;
  world_ranking?: string;
}

export const getStaticPaths = (async () => {
  const tournaments = await getCollection('tournaments', (t) => t.data.lang === 'en');
  return tournaments.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const status = tournamentStatus(entry);
const hero = tournamentImage(entry);
const date = parseNoDate(entry.data.date);
const path = `/en/turneringer/${entry.data.slug}`;
const seo = seoForPath(path);
const players =
  (registrations.tournaments as Record<string, Player[]>)[entry.data.slug]?.filter(
    (p) => p.name && p.name.toLowerCase() !== 'name',
  ) ?? [];
const priceList = entry.data.prices?.split(';').map((s) => s.trim()).filter(Boolean) ?? [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: entry.data.name,
  url: `https://www.puck.no${path}/`,
  ...(date && { startDate: date.toISOString().slice(0, 10) }),
  eventStatus:
    status === 'past' ? 'https://schema.org/EventCompleted' : 'https://schema.org/EventScheduled',
  ...(entry.data.location && {
    location: {
      '@type': 'Place',
      name: entry.data.location,
      address: { '@type': 'PostalAddress', addressCountry: 'NO' },
    },
  }),
  organizer: {
    '@type': 'SportsOrganization',
    name: 'Norwegian Table Hockey Association',
    url: 'https://www.puck.no/en/',
  },
};
---

<BaseLayout
  lang="en"
  title={seo?.title ?? `${entry.data.name} | Bordhockeyforbundet`}
  description={seo?.description || null}
  canonicalPath={path}
  noUrl={path.replace(/^\/en/, '')}
  enUrl={path}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <p class="text-sm">
      <a href="/en/turneringer/" class="font-semibold text-brand no-underline hover:underline"
        >&larr; {t('en', 'tournaments')}</a
      >
    </p>

    <header class="mt-4 border-b border-slate-200 pb-6">
      <h1 class="text-3xl font-extrabold text-navy sm:text-4xl">{entry.data.name}</h1>
      <p class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-600">
        <span class="inline-flex items-center gap-1.5 font-semibold text-navy">
          <span
            class:list={[
              'h-2 w-2 rounded-full',
              status === 'upcoming' ? 'bg-green-500' : 'bg-slate-400',
            ]}
            aria-hidden="true"></span>
          {t('en', status)}
        </span>
        <span aria-hidden="true">·</span>
        <time>{formatNoDate(entry.data.date, 'en')}</time>
        {
          entry.data.location && (
            <>
              <span aria-hidden="true">·</span>
              <span>{entry.data.location}</span>
            </>
          )
        }
      </p>
    </header>

    {
      hero && (
        <figure class="mt-6">
          <img src={hero} alt={entry.data.name} class="aspect-[21/9] w-full rounded-lg object-cover" />
        </figure>
      )
    }

    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_20rem]">
      <div class:list={['rich-text tournament-body order-2 lg:order-1', hero && 'hide-first-image']}>
        <Content />
      </div>

      <aside class="order-1 h-fit rounded-lg border border-slate-200 bg-white lg:order-2">
        <h2 class="border-b border-slate-200 px-5 py-3 text-xs font-bold uppercase tracking-wide text-slate-500">
          Facts
        </h2>
        <dl class="px-5 text-sm">
          <div class="flex justify-between gap-4 border-b border-slate-100 py-3">
            <dt class="text-slate-500">{t('en', 'date')}</dt>
            <dd class="text-right font-semibold text-navy">{formatNoDate(entry.data.date, 'en')}</dd>
          </div>
          {
            entry.data.location && (
              <div class="flex justify-between gap-4 border-b border-slate-100 py-3">
                <dt class="text-slate-500">{t('en', 'location')}</dt>
                <dd class="text-right font-semibold text-navy">{entry.data.location}</dd>
              </div>
            )
          }
          {
            priceList.length > 0 && (
              <div class="py-3">
                <dt class="text-slate-500">{t('en', 'prices')}</dt>
                <dd class="mt-1 space-y-0.5 font-semibold text-navy">
                  {priceList.map((price) => (
                    <div>{price}</div>
                  ))}
                </dd>
              </div>
            )
          }
        </dl>
        {
          status === 'upcoming' && (
            <div class="border-t border-slate-200 p-5">
              <a href="#registration" class="btn-primary block text-center no-underline">
                {t('en', 'registerPlayer')}
              </a>
            </div>
          )
        }
      </aside>
    </div>

    {
      status === 'upcoming' && (
        <div id="registration" class="my-10 rounded-lg border border-slate-200 bg-white p-6 scroll-mt-6">
          <RegistrationForm lang="en" slug={entry.data.slug} teamMin={entry.data.teamMin} teamMax={entry.data.teamMax} />
        </div>
      )
    }

    <div id="participants" class="scroll-mt-6">
      <ParticipantList slug={entry.data.slug} players={players} lang="en" />
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="en"
  title="404 – Kioskenstrøm | Bordhockeyforbundet"
  description="The page you were looking for does not exist."
  canonicalPath="/en/404"
  noUrl={null}
  enUrl={null}
  noindex={true}
>
  <section class="mx-auto max-w-2xl px-4 py-16 text-center sm:py-24">
    <p aria-hidden="true" class="text-8xl font-extralight leading-none tracking-tight text-navy/25 sm:text-9xl">
      404
    </p>
    <h1 class="mt-4 text-4xl font-extrabold text-navy sm:text-5xl">Kioskenstrøm</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-slate-600">
      Don't take it personally. No one has ever scored a Kioskenstrøm in an official match, and
      no one has ever found this page. You're in good company, though.
    </p>
    <div class="mt-8">
      <a href="/en/lær-bordhockey-kombinasjoner/#kioskenstrøm" class="btn-primary">Learn a Kioskenstrøm instead</a>
      <p class="mt-3 text-sm text-slate-500">It's impossible too — but over 200 other tricks actually exist.</p>
    </div>
    <nav aria-label="Further" class="mt-12 text-sm text-slate-500">
      <a href="/en/" class="font-semibold text-navy no-underline hover:text-brand hover:underline">Home</a>
      <span aria-hidden="true" class="mx-2">·</span>
      <a href="/en/turneringer/" class="font-semibold text-navy no-underline hover:text-brand hover:underline"
        >Tournaments</a
      >
      <span aria-hidden="true" class="mx-2">·</span>
      <a href="/en/blog/" class="font-semibold text-navy no-underline hover:text-brand hover:underline">News</a>
    </nav>
  </section>
</BaseLayout>

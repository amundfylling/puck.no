---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostArticle from '../../components/PostArticle.astro';
import { postMirrorsNoToEn } from '../../lib/i18n';
import { seoForPath } from '../../lib/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts', (p) => p.data.lang === 'no');
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const path = `/post/${post.data.slug}`;
const seo = seoForPath(path);
const enSlug = postMirrorsNoToEn[post.data.slug];
---

<BaseLayout
  lang="no"
  title={seo?.title ?? `${post.data.title} | Bordhockeyforbundet`}
  description={seo?.description || post.data.description}
  canonicalPath={path}
  noUrl={path}
  enUrl={enSlug ? `/en/post/${enSlug}` : null}
  ogImage={post.data.cover ?? null}
  ogType="article"
>
  <PostArticle post={post} lang="no" />
</BaseLayout>

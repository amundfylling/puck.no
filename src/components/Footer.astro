---
import { navItems, t, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
const flatLinks = navItems(lang).flatMap((i) => (i.children ? [i, ...i.children] : [i]));
const orgName = lang === 'en' ? 'Norwegian Table Hockey Association' : 'Norges Bordhockeyforbund';
---

<footer class="mt-16 bg-navy text-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <p class="text-lg font-extrabold">NBHF</p>
      <p class="mt-1 text-sm text-slate-300">{orgName}</p>
      <p class="mt-4 text-sm">
        <span class="font-semibold">{t(lang, 'footerContact')}:</span>
        <a href="mailto:amund.fylling@puck.no" class="ml-1 text-slate-200 underline underline-offset-2 hover:text-white"
          >amund.fylling@puck.no</a
        >
      </p>
    </div>
    <nav aria-label={t(lang, 'menuLabel')}>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
        {
          flatLinks.map((item) => (
            <li>
              <a
                href={item.href}
                {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
                class="text-slate-300 no-underline hover:text-white hover:underline"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="text-sm text-slate-300">
      <p>
        <a
          href={lang === 'en' ? '/en/blog-feed.xml' : '/blog-feed.xml'}
          class="text-slate-300 no-underline hover:text-white hover:underline">RSS</a
        >
      </p>
      <p class="mt-2">
        <a
          href="https://www.ithf.info/stiga/ithf/ithf.asp"
          target="_blank"
          rel="noopener"
          class="text-slate-300 no-underline hover:text-white hover:underline">ITHF</a
        >
      </p>
    </div>
  </div>
  <div class="border-t border-white/10">
    <p class="mx-auto max-w-6xl px-4 py-4 text-xs text-slate-400">© {year} Norges Bordhockeyforbund</p>
  </div>
</footer>

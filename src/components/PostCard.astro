---
import { formatDate } from '../lib/dates';
import { categorySlug } from '../lib/content';
import type { Post } from '../lib/content';
import type { Lang } from '../lib/i18n';

interface Props {
  post: Post;
  lang: Lang;
  /** Above-the-fold images (e.g. first cards) can load eagerly. */
  eager?: boolean;
}

const { post, lang, eager = false } = Astro.props;
const href = `${lang === 'en' ? '/en' : ''}/post/${post.data.slug}`;
---

<article class="flex flex-col overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-md">
  {
    post.data.cover && (
      <a href={href} tabindex="-1" aria-hidden="true">
        <img
          src={post.data.cover}
          alt=""
          loading={eager ? 'eager' : 'lazy'}
          class="aspect-video w-full object-cover"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-4">
    <p class="text-xs text-slate-500">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
    </p>
    <h3 class="mt-1 text-lg font-bold leading-snug">
      <a href={href} class="text-navy no-underline hover:text-brand">{post.data.title}</a>
    </h3>
    {post.data.description && <p class="mt-2 line-clamp-3 text-sm text-slate-600">{post.data.description}</p>}
    {
      post.data.categories.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2" aria-label={lang === 'en' ? 'Categories' : 'Kategorier'}>
          {post.data.categories.map((cat) => (
            <li>
              <a
                href={`${lang === 'en' ? '/en' : ''}/blog/categories/${categorySlug(cat)}`}
                class="rounded-full bg-ice px-2.5 py-0.5 text-xs font-semibold text-navy no-underline hover:bg-navy hover:text-white"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

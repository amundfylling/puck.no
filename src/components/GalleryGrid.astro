---
import { t, type Lang } from '../lib/i18n';

interface Props {
  slug: string;
  title: string;
  /** Full-size image paths (/media/galleries/<slug>/<file>). */
  images: string[];
  lang: Lang;
}

const { slug, title, images, lang } = Astro.props;
const thumbOf = (src: string) => src.replace(`/media/galleries/${slug}/`, `/media/galleries/${slug}/thumbs/`);
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" data-gallery>
  {
    images.map((src, i) => (
      <button
        type="button"
        data-thumb
        data-full={src}
        aria-haspopup="dialog"
        aria-label={`${title} — ${t(lang, 'photoOf')} ${i + 1} ${t(lang, 'of')} ${images.length}`}
        class="overflow-hidden rounded-lg focus-visible:outline-brand"
      >
        <img
          src={thumbOf(src)}
          alt={`${title}, ${t(lang, 'photoOf')} ${i + 1}`}
          loading="lazy"
          class="aspect-square w-full object-cover transition-transform hover:scale-105"
        />
      </button>
    ))
  }
</div>

<div
  data-lightbox
  hidden
  role="dialog"
  aria-modal="true"
  aria-label={title}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4"
>
  <button
    type="button"
    data-close
    aria-label={t(lang, 'close')}
    class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-2xl text-white hover:bg-white/25"
    >&times;</button
  >
  <button
    type="button"
    data-prev
    aria-label={t(lang, 'previousImage')}
    class="absolute left-2 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-3xl text-white hover:bg-white/25 sm:left-4"
    >&lsaquo;</button
  >
  <figure class="flex max-h-full max-w-5xl flex-col items-center gap-2">
    <img data-full-img src="" alt="" class="max-h-[82vh] w-auto max-w-full rounded object-contain" />
    <figcaption data-counter class="text-sm text-white/80"></figcaption>
  </figure>
  <button
    type="button"
    data-next
    aria-label={t(lang, 'nextImage')}
    class="absolute right-2 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-3xl text-white hover:bg-white/25 sm:right-4"
    >&rsaquo;</button
  >
</div>

<script>
  const lightboxEl = document.querySelector<HTMLElement>('[data-lightbox]');
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  if (lightboxEl && gallery) {
    const lightbox = lightboxEl;
    const img = lightbox.querySelector<HTMLImageElement>('[data-full-img]')!;
    const counter = lightbox.querySelector<HTMLElement>('[data-counter]')!;
    const btnClose = lightbox.querySelector<HTMLButtonElement>('[data-close]')!;
    const btnPrev = lightbox.querySelector<HTMLButtonElement>('[data-prev]')!;
    const btnNext = lightbox.querySelector<HTMLButtonElement>('[data-next]')!;
    const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>('[data-thumb]'));
    const focusables = [btnClose, btnPrev, btnNext];
    let index = 0;
    let lastFocused: HTMLElement | null = null;

    function show(i: number) {
      index = (i + thumbs.length) % thumbs.length;
      const btn = thumbs[index];
      img.src = btn.dataset.full ?? '';
      img.alt = btn.getAttribute('aria-label') ?? '';
      counter.textContent = `${index + 1} / ${thumbs.length}`;
    }
    function open(i: number) {
      lastFocused = document.activeElement as HTMLElement | null;
      show(i);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      btnClose.focus();
    }
    function close() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
      img.src = '';
      lastFocused?.focus();
    }

    thumbs.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', () => show(index - 1));
    btnNext.addEventListener('click', () => show(index + 1));
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(index - 1);
      else if (e.key === 'ArrowRight') show(index + 1);
      else if (e.key === 'Tab') {
        // simple focus trap within the dialog
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

---
import { categorySlug, type Page, type Post } from '../lib/content';
import { t, type Lang } from '../lib/i18n';
import PostCard from './PostCard.astro';

interface Props {
  lang: Lang;
  entry: Page;
  posts: Post[];
  page: number;
  pageCount: number;
  categories: string[];
}

const { lang, entry, posts, page, pageCount, categories } = Astro.props;
const prefix = lang === 'en' ? '/en' : '';
const pageUrl = (n: number) => (n === 1 ? `${prefix}/blog/` : `${prefix}/blog/${n}/`);
---

<section class="mx-auto max-w-6xl px-4 py-10">
  <h1 class="text-3xl font-extrabold text-navy">{entry.data.title}</h1>
  {entry.data.description && <p class="mt-3 max-w-2xl text-slate-600">{entry.data.description}</p>}

  <nav aria-label={t(lang, 'categories')} class="mt-6">
    <ul class="flex flex-wrap gap-2">
      <li>
        <a
          href={`${prefix}/blog/`}
          aria-current="page"
          class="inline-flex min-h-[44px] items-center rounded-full bg-navy px-3 py-1.5 text-sm font-semibold text-white no-underline"
          >{t(lang, 'allPosts')}</a
        >
      </li>
      {
        categories.map((cat) => (
          <li>
            <a
              href={`${prefix}/blog/categories/${categorySlug(cat)}/`}
              class="inline-flex min-h-[44px] items-center rounded-full bg-ice px-3 py-1.5 text-sm font-semibold text-navy no-underline hover:bg-navy hover:text-white"
            >
              {cat}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="mt-8 space-y-6">
    {page === 1 && posts.length > 0 && <PostCard post={posts[0]} lang={lang} eager featured />}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.slice(page === 1 ? 1 : 0).map((post, i) => <PostCard post={post} lang={lang} eager={page === 1 && i < 2} />)}
    </div>
  </div>

  {
    pageCount > 1 && (
      <nav aria-label={t(lang, 'pageOf')} class="mt-10">
        <ul class="flex flex-wrap items-center justify-center gap-2">
          {page > 1 && (
            <li>
              <a href={pageUrl(page - 1)} class="btn-outline !px-3 !py-1.5 text-sm">
                &larr; {t(lang, 'previous')}
              </a>
            </li>
          )}
          {Array.from({ length: pageCount }, (_, i) => i + 1).map((n) => (
            <li>
              <a
                href={pageUrl(n)}
                aria-current={n === page ? 'page' : undefined}
                aria-label={`${t(lang, 'pageOf')} ${n}`}
                class:list={[
                  'rounded px-3 py-1.5 text-sm font-semibold no-underline',
                  n === page ? 'bg-brand text-white' : 'text-navy hover:bg-ice',
                ]}
              >
                {n}
              </a>
            </li>
          ))}
          {page < pageCount && (
            <li>
              <a href={pageUrl(page + 1)} class="btn-outline !px-3 !py-1.5 text-sm">
                {t(lang, 'next')} &rarr;
              </a>
            </li>
          )}
        </ul>
      </nav>
    )
  }
</section>

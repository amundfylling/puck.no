---
import { t, type Lang } from '../lib/i18n';
import { formatNoDate } from '../lib/dates';
import type { TournamentView } from '../lib/content';

interface Props {
  view: TournamentView;
  lang: Lang;
  /** Large hero-style card (next tournament). */
  featured?: boolean;
}

const { view, lang, featured = false } = Astro.props;
const { entry, status, image } = view;
const href = lang === 'en' ? `/en/turneringer/${entry.data.slug}/` : `/turneringer/${entry.data.slug}/`;
const dateLabel = formatNoDate(entry.data.date, lang);
---

{
  featured ? (
    <a href={href} class="group mt-4 grid gap-4 no-underline sm:grid-cols-[16rem_1fr] sm:gap-6">
      {image && (
        <img
          src={image}
          alt=""
          loading="lazy"
          class="aspect-video w-full rounded-lg object-cover"
        />
      )}
      <div class="flex flex-col justify-center">
        <h3 class="text-xl font-bold text-navy group-hover:underline">{view.name}</h3>
        <p class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-slate-600">
          <span
            class:list={[
              'h-2 w-2 rounded-full',
              status === 'upcoming' ? 'bg-green-500' : 'bg-slate-400',
            ]}
            aria-hidden="true"
          />
          {dateLabel}
          {
            entry.data.location && (
              <>
                <span aria-hidden="true">·</span>
                <span>{entry.data.location}</span>
              </>
            )
          }
        </p>
        <p class="mt-2 text-sm font-semibold text-brand">{t(lang, 'viewTournament')} &rarr;</p>
      </div>
    </a>
  ) : (
    <a href={href} class="group flex items-center gap-4 py-3 no-underline hover:bg-ice/50">
      {image && (
        <img
          src={image}
          alt=""
          loading="lazy"
          class="h-12 w-16 shrink-0 rounded object-cover"
        />
      )}
      <div class="min-w-0 grow">
        <p class="truncate font-semibold text-navy group-hover:underline">{view.name}</p>
        <p class="text-sm text-slate-500">{dateLabel}</p>
      </div>
      <span aria-hidden="true" class="text-slate-400 group-hover:text-navy">&rarr;</span>
    </a>
  )
}

---
import { t, type Lang } from '../lib/i18n';
import type { TournamentView } from '../lib/content';
import TournamentCard from './TournamentCard.astro';

interface Props {
  lang: Lang;
  views: TournamentView[];
}

const { lang, views } = Astro.props;
const upcoming = views.filter((v) => v.status === 'upcoming');
const past = views.filter((v) => v.status === 'past');
---

<section class="mx-auto max-w-4xl px-4 py-10">
  <h1 class="text-3xl font-extrabold text-navy">{lang === 'en' ? 'Tournaments' : 'Turneringer'}</h1>

  <div class="mt-8 flex items-baseline gap-3">
    <h2 class="text-xl font-bold text-navy">{t(lang, 'upcomingTournaments')}</h2>
    <span class="text-sm text-slate-500">({upcoming.length})</span>
  </div>
  <div class="mt-4 space-y-3">
    {
      upcoming.length > 0 ? (
        <>
          <TournamentCard view={upcoming[0]} lang={lang} featured />
          {upcoming.slice(1).map((view) => <TournamentCard view={view} lang={lang} />)}
        </>
      ) : (
        <p class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-500">
          {t(lang, 'noUpcomingTournaments')}
        </p>
      )
    }
  </div>

  <div class="mt-10 flex items-baseline gap-3">
    <h2 class="text-xl font-bold text-navy">{t(lang, 'pastTournaments')}</h2>
    <span class="text-sm text-slate-500">({past.length})</span>
  </div>
  <div class="mt-4 space-y-3">
    {past.map((view) => <TournamentCard view={view} lang={lang} />)}
  </div>
</section>

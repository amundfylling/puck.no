---
interface Props {
  /** Unique id prefix for aria wiring. */
  id: string;
  label: string;
  placeholder: string;
  fallbackToggle: string;
  fallbackLabel: string;
}

const { id, label, placeholder, fallbackToggle, fallbackLabel } = Astro.props;
const listId = `${id}-listbox`;
---

<div class="player-select relative" data-player-select>
  <label class="grid gap-1 text-sm font-semibold text-navy" data-combo-field>
    {label}
    <span aria-hidden="true" class="text-brand">*</span>
    <input
      data-combo-input
      type="text"
      role="combobox"
      aria-expanded="false"
      aria-autocomplete="list"
      aria-controls={listId}
      autocomplete="off"
      spellcheck="false"
      placeholder={placeholder}
      class="rounded border border-slate-300 px-3 py-2 font-normal"
    />
  </label>
  <ul
    id={listId}
    data-combo-list
    role="listbox"
    aria-label={label}
    class="absolute left-0 right-0 z-20 mt-1 hidden max-h-64 overflow-auto rounded-md border border-slate-300 bg-white shadow-lg"
  >
  </ul>
  <p data-combo-chosen class="mt-1 hidden text-xs font-semibold text-green-800"></p>
  <button
    type="button"
    data-combo-fallback-toggle
    class="mt-1 inline-block py-3 text-xs font-semibold text-navy underline underline-offset-2 hover:text-brand"
  >
    {fallbackToggle}
  </button>
  <label class="mt-2 hidden gap-1 text-sm font-semibold text-navy" data-combo-fallback-field>
    {fallbackLabel}
    <span aria-hidden="true" class="text-brand">*</span>
    <input
      data-combo-fallback-input
      type="text"
      maxlength="200"
      class="rounded border border-slate-300 px-3 py-2 font-normal"
    />
  </label>
</div>

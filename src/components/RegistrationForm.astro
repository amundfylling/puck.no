---
import PlayerSelect from './PlayerSelect.astro';
import type { Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  /** Tournament slug — posted to the API. */
  slug: string;
}

const { lang, slug } = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined;

// PHASE 3: live registration form -> POST /api/registrations (Cloudflare
// Pages Function + D1). Player is chosen from the live ITHF world ranking
// (searchable combobox, /ranking.json loaded lazily); country + world
// ranking are derived server-side. Vanilla-JS island, no framework.
const l =
  lang === 'en'
    ? {
        playerTab: 'Register player',
        teamTab: 'Register team',
        name: 'Name',
        searchPlaceholder: 'Search the world ranking…',
        loading: 'Loading the world ranking…',
        noResults: 'No players found',
        fallbackToggle: "I can't find my name",
        fallbackLabel: 'Name (new player without world ranking)',
        player1: 'Player 1',
        player2: 'Player 2',
        email: 'Email',
        phone: 'Phone number',
        submit: 'Register',
        sending: 'Registering…',
        success: 'Takk for din registrering!',
        pickPlayer: 'Select a player from the list, or use "I can\'t find my name".',
        pickBoth: 'Select both players, or enter both names.',
        privacy:
          'We store your name, email and phone number to manage tournament registrations. Contact amund.fylling@puck.no for access or deletion.',
        noscript: 'Registration requires JavaScript.',
        noKey: 'Registration is not configured (missing Turnstile site key).',
      }
    : {
        playerTab: 'Registrer spiller',
        teamTab: 'Registrer lag',
        name: 'Navn',
        searchPlaceholder: 'Søk i verdensrankingen…',
        loading: 'Laster verdensrankingen…',
        noResults: 'Ingen spillere funnet',
        fallbackToggle: 'Jeg finner ikke navnet mitt',
        fallbackLabel: 'Navn (ny spiller uten verdensranking)',
        player1: 'Spiller 1',
        player2: 'Spiller 2',
        email: 'Epost',
        phone: 'Telefonnummer',
        submit: 'Registrer',
        sending: 'Registrerer…',
        success: 'Takk for din registrering!',
        pickPlayer: 'Velg en spiller fra listen, eller bruk «Jeg finner ikke navnet mitt».',
        pickBoth: 'Velg begge spillerne, eller skriv inn begge navnene.',
        privacy:
          'Vi lagrer navn, e-post og telefonnummer for å administrere turneringspåmeldinger. Kontakt amund.fylling@puck.no for innsyn eller sletting.',
        noscript: 'Påmelding krever JavaScript.',
        noKey: 'Registreringen er ikke konfigurert (mangler Turnstile-nøkkel).',
      };
---

<section id="pamelding" aria-labelledby="pamelding-heading" class="my-10 rounded-lg border border-slate-200 bg-ice p-6" data-registration data-slug={slug} data-messages={JSON.stringify({ pickPlayer: l.pickPlayer, pickBoth: l.pickBoth, loading: l.loading, noResults: l.noResults })}>
  <h2 id="pamelding-heading" class="text-xl font-bold text-navy">{l.playerTab} / {l.teamTab}</h2>

  <noscript>
    <p class="mt-2 font-semibold text-brand">{l.noscript}</p>
  </noscript>

  {
    !siteKey && (
      <p class="mt-2 rounded bg-yellow-100 px-3 py-2 text-sm text-yellow-900">{l.noKey}</p>
    )
  }

  <div role="tablist" aria-label={l.playerTab + ' / ' + l.teamTab} class="mt-4 flex gap-2">
    <button type="button" role="tab" data-tab="player" aria-selected="true" class="tab-btn btn-primary !px-4 !py-2 text-sm">{l.playerTab}</button>
    <button type="button" role="tab" data-tab="team" aria-selected="false" class="tab-btn btn-outline !px-4 !py-2 text-sm">{l.teamTab}</button>
  </div>

  <form data-form="player" class="mt-4 grid max-w-lg gap-3">
    <PlayerSelect
      id="reg-player"
      label={l.name}
      placeholder={l.searchPlaceholder}
      fallbackToggle={l.fallbackToggle}
      fallbackLabel={l.fallbackLabel}
    />
    <label class="grid gap-1 text-sm font-semibold text-navy">
      {l.email} <span aria-hidden="true" class="text-brand">*</span>
      <input name="email" type="email" required maxlength="254" autocomplete="email" class="rounded border border-slate-300 px-3 py-2 font-normal" />
    </label>
    <label class="grid gap-1 text-sm font-semibold text-navy">
      {l.phone}
      <input name="phone" type="tel" maxlength="30" autocomplete="tel" class="rounded border border-slate-300 px-3 py-2 font-normal" />
    </label>
    {siteKey && <div class="cf-turnstile" data-sitekey={siteKey}></div>}
    <div>
      <button type="submit" data-submit data-sending={l.sending} disabled={!siteKey} class="btn-primary disabled:cursor-not-allowed disabled:opacity-50">
        {l.submit}
      </button>
    </div>
    <p data-message data-success={l.success} role="status" aria-live="polite" class="hidden rounded px-3 py-2 text-sm font-semibold"></p>
  </form>

  <form data-form="team" class="mt-4 hidden max-w-lg gap-3">
    <PlayerSelect
      id="reg-team-1"
      label={l.player1}
      placeholder={l.searchPlaceholder}
      fallbackToggle={l.fallbackToggle}
      fallbackLabel={l.fallbackLabel}
    />
    <PlayerSelect
      id="reg-team-2"
      label={l.player2}
      placeholder={l.searchPlaceholder}
      fallbackToggle={l.fallbackToggle}
      fallbackLabel={l.fallbackLabel}
    />
    <label class="grid gap-1 text-sm font-semibold text-navy">
      {l.email} <span aria-hidden="true" class="text-brand">*</span>
      <input name="email" type="email" required maxlength="254" autocomplete="email" class="rounded border border-slate-300 px-3 py-2 font-normal" />
    </label>
    <label class="grid gap-1 text-sm font-semibold text-navy">
      {l.phone}
      <input name="phone" type="tel" maxlength="30" autocomplete="tel" class="rounded border border-slate-300 px-3 py-2 font-normal" />
    </label>
    {siteKey && <div class="cf-turnstile" data-sitekey={siteKey}></div>}
    <div>
      <button type="submit" data-submit data-sending={l.sending} disabled={!siteKey} class="btn-primary disabled:cursor-not-allowed disabled:opacity-50">
        {l.submit}
      </button>
    </div>
    <p data-message data-success={l.success} role="status" aria-live="polite" class="hidden rounded px-3 py-2 text-sm font-semibold"></p>
  </form>

  <p class="mt-4 text-xs text-slate-500">{l.privacy}</p>
</section>

{siteKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>}

<script>
  const root = document.querySelector<HTMLElement>('[data-registration]');
  if (root) {
    const slug = root.dataset.slug!;
    const msgs = JSON.parse(root.dataset.messages ?? '{}') as Record<string, string>;

    /* ---------- tabs ---------- */
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const forms = Array.from(root.querySelectorAll<HTMLFormElement>('[data-form]'));
    tabs.forEach((tab) =>
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          const active = t === tab;
          t.setAttribute('aria-selected', String(active));
          t.classList.toggle('btn-primary', active);
          t.classList.toggle('btn-outline', !active);
        });
        forms.forEach((f) => {
          const show = f.dataset.form === tab.dataset.tab;
          f.classList.toggle('hidden', !show);
          f.classList.toggle('grid', show);
        });
      }),
    );

    /* ---------- ranking comboboxes ---------- */
    type PlayerRow = [number, number, string, string, string]; // rank, id, name, club, nation
    let rankingPromise: Promise<PlayerRow[]> | null = null;
    function loadRanking(): Promise<PlayerRow[]> {
      rankingPromise ??= fetch('/ranking.json').then((r) => {
        if (!r.ok) throw new Error(`ranking HTTP ${r.status}`);
        return r.json() as Promise<PlayerRow[]>;
      });
      return rankingPromise;
    }
    const norm = (s: string) => s.normalize('NFD').replace(/\p{M}/gu, '').toLowerCase();
    const debounce = <A extends unknown[]>(fn: (...a: A) => void, ms: number) => {
      let t: ReturnType<typeof setTimeout>;
      return (...a: A) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...a), ms);
      };
    };

    interface SelectState {
      playerId: number | null;
      fallback: boolean;
    }

    function initPlayerSelect(box: HTMLElement): SelectState {
      const input = box.querySelector<HTMLInputElement>('[data-combo-input]')!;
      const list = box.querySelector<HTMLUListElement>('[data-combo-list]')!;
      const chosen = box.querySelector<HTMLElement>('[data-combo-chosen]')!;
      const field = box.querySelector<HTMLElement>('[data-combo-field]')!;
      const fallbackField = box.querySelector<HTMLElement>('[data-combo-fallback-field]')!;
      const fallbackInput = box.querySelector<HTMLInputElement>('[data-combo-fallback-input]')!;
      const toggle = box.querySelector<HTMLButtonElement>('[data-combo-fallback-toggle]')!;
      const state: SelectState = { playerId: null, fallback: false };
      let players: PlayerRow[] | null = null;
      let items: PlayerRow[] = [];
      let active = -1;

      function close() {
        list.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
        input.removeAttribute('aria-activedescendant');
        active = -1;
      }
      function open() {
        list.classList.remove('hidden');
        input.setAttribute('aria-expanded', 'true');
      }
      function renderItems() {
        list.replaceChildren();
        if (items.length === 0) {
          const li = document.createElement('li');
          li.className = 'px-3 py-2 text-sm text-slate-500';
          li.textContent = msgs.noResults ?? 'Ingen spillere funnet';
          list.appendChild(li);
          return;
        }
        items.forEach((p, i) => {
          const li = document.createElement('li');
          li.id = `${list.id}-opt-${i}`;
          li.setAttribute('role', 'option');
          li.setAttribute('aria-selected', 'false');
          li.className = 'cursor-pointer px-3 py-2 text-sm hover:bg-ice aria-selected:bg-ice';
          const b = document.createElement('span');
          b.className = 'font-semibold text-navy';
          b.textContent = p[2];
          const meta = document.createElement('span');
          meta.className = 'ml-2 text-xs text-slate-500';
          meta.textContent = `${p[3]} · ${p[4]} · WR ${p[0]}`;
          li.append(b, meta);
          li.addEventListener('pointerdown', (e) => {
            e.preventDefault(); // keep focus on input
            select(i);
          });
          list.appendChild(li);
        });
      }
      function search() {
        if (!players) return;
        const q = norm(input.value.trim());
        if (!q) {
          close();
          return;
        }
        items = players.filter((p) => norm(p[2]).includes(q)).slice(0, 50);
        renderItems();
        open();
      }
      function select(i: number) {
        const p = items[i];
        if (!p) return;
        state.playerId = p[1];
        input.value = p[2];
        chosen.textContent = `WR ${p[0]} · ${p[4]} · ${p[3]}`;
        chosen.classList.remove('hidden');
        close();
      }

      input.addEventListener('focus', () => {
        if (!players) {
          const orig = input.placeholder;
          input.placeholder = msgs.loading ?? orig;
          loadRanking()
            .then((p) => {
              players = p;
              input.placeholder = orig;
              search();
            })
            .catch(() => {
              input.placeholder = orig;
            });
        } else {
          search();
        }
      });
      input.addEventListener(
        'input',
        debounce(() => {
          state.playerId = null;
          chosen.classList.add('hidden');
          search();
        }, 150),
      );
      input.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          e.preventDefault();
          if (list.classList.contains('hidden') || items.length === 0) return;
          active = e.key === 'ArrowDown' ? (active + 1) % items.length : (active - 1 + items.length) % items.length;
          input.setAttribute('aria-activedescendant', `${list.id}-opt-${active}`);
          list.querySelectorAll('[role="option"]').forEach((el, i) => el.setAttribute('aria-selected', String(i === active)));
          document.getElementById(`${list.id}-opt-${active}`)?.scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter') {
          if (active >= 0 && items[active]) {
            e.preventDefault();
            select(active);
          }
        } else if (e.key === 'Escape') {
          close();
        } else if (e.key === 'Tab') {
          close();
        }
      });
      input.addEventListener('blur', () => setTimeout(close, 150));

      toggle.addEventListener('click', () => {
        state.fallback = !state.fallback;
        state.playerId = null;
        chosen.classList.add('hidden');
        field.classList.toggle('hidden', state.fallback);
        fallbackField.classList.toggle('hidden', !state.fallback);
        fallbackField.classList.toggle('grid', state.fallback);
        fallbackInput.required = state.fallback;
        if (state.fallback) fallbackInput.focus();
        else input.focus();
      });
      return state;
    }

    function readPlayer(box: HTMLElement, state: SelectState): { playerId?: number; name?: string } {
      if (state.playerId != null) return { playerId: state.playerId };
      const fallbackInput = box.querySelector<HTMLInputElement>('[data-combo-fallback-input]')!;
      const input = box.querySelector<HTMLInputElement>('[data-combo-input]')!;
      const name = (state.fallback ? fallbackInput.value : input.value).trim();
      return name ? { name } : {};
    }

    /* ---------- submit ---------- */
    forms.forEach((form) => {
      const btn = form.querySelector<HTMLButtonElement>('[data-submit]')!;
      const msg = form.querySelector<HTMLElement>('[data-message]')!;
      const btnLabel = btn.textContent ?? '';
      const boxes = Array.from(form.querySelectorAll<HTMLElement>('[data-player-select]'));
      const states = boxes.map(initPlayerSelect);
      const type = form.dataset.form as 'player' | 'team';

      function showMessage(text: string, ok: boolean) {
        msg.textContent = text;
        msg.classList.remove('hidden', 'bg-green-100', 'text-green-900', 'bg-red-100', 'text-red-900');
        msg.classList.add(ok ? 'bg-green-100' : 'bg-red-100', ok ? 'text-green-900' : 'text-red-900');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;

        const players = states.map((s, i) => readPlayer(boxes[i], s));
        let payload: Record<string, unknown>;
        if (type === 'team') {
          const ids = players.map((p) => p.playerId).filter((v): v is number => v != null);
          if (ids.length === 2) {
            payload = { playerIds: ids };
          } else {
            const names = players.map((p) => p.name?.trim() ?? '');
            if (names.some((n) => !n)) {
              showMessage(msgs.pickBoth ?? 'Velg begge spillerne.', false);
              return;
            }
            payload = { name: names.join(' / ') };
          }
        } else {
          if (players[0].playerId == null && !players[0].name) {
            showMessage(msgs.pickPlayer ?? 'Velg en spiller.', false);
            return;
          }
          payload = players[0].playerId != null ? { playerId: players[0].playerId } : { name: players[0].name };
        }

        btn.disabled = true;
        btn.textContent = btn.dataset.sending ?? btnLabel;
        try {
          const token = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]')?.value ?? '';
          const data = Object.fromEntries(new FormData(form).entries());
          const res = await fetch('/api/registrations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tournament_slug: slug,
              type,
              ...payload,
              email: data.email,
              phone: data.phone || null,
              turnstileToken: token,
            }),
          });
          const body = (await res.json().catch(() => ({}))) as { error?: string };
          if (res.ok) {
            showMessage(msg.dataset.success ?? 'Takk!', true);
            form.reset();
            states.forEach((s, i) => {
              s.playerId = null;
              boxes[i].querySelector('[data-combo-chosen]')?.classList.add('hidden');
            });
            document.dispatchEvent(new CustomEvent('registrations:refresh'));
          } else {
            showMessage(body.error ?? 'Noe gikk galt. Prøv igjen senere.', false);
          }
        } catch {
          showMessage('Nettverksfeil. Prøv igjen.', false);
        } finally {
          btn.disabled = false;
          btn.textContent = btnLabel;
          const w = (window as unknown as { turnstile?: { reset: (el?: HTMLElement) => void } }).turnstile;
          form.querySelectorAll<HTMLElement>('.cf-turnstile').forEach((el) => w?.reset(el));
        }
      });
    });
  }
</script>

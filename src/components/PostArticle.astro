---
import { render } from 'astro:content';
import { formatDate } from '../lib/dates';
import { categorySlug, type Post } from '../lib/content';
import { t, type Lang } from '../lib/i18n';

interface Props {
  post: Post;
  lang: Lang;
}

const { post, lang } = Astro.props;
const { Content } = await render(post);
const prefix = lang === 'en' ? '/en' : '';
---

<article class="mx-auto max-w-3xl px-4 py-10">
  <p class="text-sm">
    <a href={`${prefix}/blog/`} class="font-semibold text-brand no-underline hover:underline"
      >&larr; {t(lang, 'backToBlog')}</a
    >
  </p>
  <h1 class="mt-4 text-3xl font-extrabold leading-tight text-navy sm:text-4xl">{post.data.title}</h1>
  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500">
    <p>
      {t(lang, 'published')}&nbsp;<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
    </p>
    {
      post.data.categories.length > 0 && (
        <ul class="flex flex-wrap gap-2">
          {post.data.categories.map((cat) => (
            <li>
              <a
                href={`${prefix}/blog/categories/${categorySlug(cat)}/`}
                class="rounded-full bg-ice px-2.5 py-0.5 text-xs font-semibold text-navy no-underline hover:bg-navy hover:text-white"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
  {
    post.data.cover && (
      <img
        src={post.data.cover}
        alt={post.data.title}
        class="mt-6 w-full rounded-lg"
        loading="eager"
        fetchpriority="high"
      />
    )
  }
  <div class="rich-text mt-8">
    <Content />
  </div>
</article>

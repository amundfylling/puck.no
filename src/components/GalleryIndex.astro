---
import { galleries, thumbOf } from '../lib/galleries';
import { t, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
// Gallery detail pages exist only in Norwegian — both indexes link there.
---

<ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    galleries.map((gallery) => (
      <li>
        <a
          href={`/bilder/${gallery.slug}/`}
          class="group block overflow-hidden rounded-lg border border-slate-200 bg-white no-underline shadow-sm transition-shadow hover:shadow-md"
        >
          <img
            src={thumbOf(gallery.slug, gallery.images[0])}
            alt={gallery.title}
            loading="lazy"
            class="aspect-video w-full object-cover transition-transform group-hover:scale-105"
          />
          <div class="p-4">
            <h2 class="text-lg font-bold text-navy group-hover:text-brand">{gallery.title}</h2>
            <p class="mt-1 text-sm text-slate-500">
              {gallery.images.length} {t(lang, 'images')}
            </p>
          </div>
        </a>
      </li>
    ))
  }
</ul>

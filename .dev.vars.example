# Copy to .dev.vars for local development (git-ignored).
# .dev.vars is read by `wrangler pages dev` (functions env), NOT by the Astro
# build — the PUBLIC_ variable must also be set when building (see .env).
#
# For local dev, use Cloudflare's official always-pass TEST keys:
#   https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Same value as PUBLIC_TURNSTILE_SITE_KEY, kept for reference:
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional: Cloudflare Access team name. When set, GET /api/admin/registrations.csv
# requires the Cf-Access-Authenticated-User-Email header (defence in depth —
# Access itself is configured in the Cloudflare dashboard, Phase 5).
# ACCESS_TEAM_NAME=your-team.cloudflareaccess.com
